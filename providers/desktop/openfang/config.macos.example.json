{
  "providerId": "oss-desktop-openfang-macos",
  "providerVersion": "0.3.0-preview",
  "targetOS": "macos",
  "allowRestrictedHost": false,
  "capabilities": [
    "observe.window_metadata",
    "observe.screenshot_hash",
    "actuate.window_focus",
    "actuate.input.type_click",
    "verify.post_action_state"
  ],
  "upstream": {
    "enabled": false,
    "baseUrl": "https://openfang-provider-macos.epydios.local",
    "observePath": "/v1alpha1/desktop-provider/observe",
    "actuatePath": "/v1alpha1/desktop-provider/actuate",
    "verifyPath": "/v1alpha1/desktop-provider/verify",
    "healthPath": "/healthz",
    "timeoutSeconds": 10,
    "headers": {
      "x-epydios-provider": "openfang-macos"
    }
  }
}
