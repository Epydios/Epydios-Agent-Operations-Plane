  "event_stream_consumption_notes": [
    "GET /v1alpha2/runtime/sessions/{sessionId}/events remains the cursor-based JSON list surface.",
    "GET /v1alpha2/runtime/sessions/{sessionId}/events/stream is the explicit event-stream surface for chat and IDE clients.",
    "Accept: text/event-stream or format=event-stream on the session events route is also valid.",
    "GET /v1alpha2/runtime/sessions/{sessionId}/timeline is the first native aggregated read model for future chat and IDE clients.",
    "POST /v1alpha2/runtime/sessions/{sessionId}/workers/{workerId}/events is the first worker-scoped write surface for native progress emission such as worker.output.delta."
  ],
  "backward_compatibility_mapping": {
    "RunRecord": "legacy-compatible Session",
    "RunCreateRequest": "Task plus Session bootstrap request",
    "ApprovalRecord": "ApprovalCheckpoint",
    "POST /runtime/terminal/sessions": "ToolAction(toolType=terminal_command)",
    "POST /runtime/integrations/invoke": "ToolAction(toolType=model_invoke) or Worker(model_invoke)",
    "EvidenceRecordResponse and EvidenceBundleResponse": "EvidenceRecord"
  },
  "migration_sequence": [
    "Add task, session, session_event, session_worker, approval_checkpoint, tool_action, and evidence_record records while keeping orchestration_runs intact.",
    "Create compatibility projection so new sessions can still expose current run summaries.",
    "Move approval, terminal, and integration-invoke actions to emit session events and tool-action records.",
    "Build chat on top of session/event streams rather than directly on run.",
    "Build Codex worker adapter against the worker contract.",
    "Build VS Code client against the same session/task contract."
  ],
  "exit_gate": "task/session/worker/event entities are real runtime records, current approval-terminal-invoke flows emit session-linked events, and one chat client plus one IDE client could use the same contract without special-case backend behavior"
}
