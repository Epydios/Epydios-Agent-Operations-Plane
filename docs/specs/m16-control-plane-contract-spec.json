{
  "id": "m16_control_plane_contract_spec_20260307",
  "status": "architecture_spec_parallelized_while_m15_blocked",
  "created_on": "2026-03-07",
  "scope": {
    "purpose": "define the stable control-plane contract for future chat, ide, cli, workflow, and worker surfaces",
    "non_goals": [
      "final chat UX",
      "final ide UX",
      "vendor-specific worker internals",
      "storage schema implementation details beyond required records"
    ]
  },
  "design_principles": [
    "AgentOps remains the control plane",
    "clients are thin surfaces over a shared contract",
    "workers are adapters behind that contract",
    "raw model invocation and managed worker execution stay distinct",
    "audit and evidence are first-class records",
    "existing run APIs remain available during migration"
  ],
  "entities": [
