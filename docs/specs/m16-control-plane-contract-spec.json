      "states": [
        "NEW",
        "READY",
        "BLOCKED",
        "IN_PROGRESS",
        "COMPLETED",
        "FAILED",
        "CANCELLED"
      ],
      "required_fields": [
        "taskId",
        "tenantId",
        "projectId",
        "source",
        "title",
        "intent",
        "requestedBy",
        "createdAt",
        "status"
